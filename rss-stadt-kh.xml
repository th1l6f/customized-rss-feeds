      <guid isPermaLink="false">https://www.bad-kreuznach.de/buergerservice/politik-und-verwaltung/archiv-pressemitteilungen/jahresarchiv-2026/juli-2026/das-vhs-programm-fuer-das-2-semester-2026-ist-erschienen/</guid>
